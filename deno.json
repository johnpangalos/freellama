{
  "tasks": {
    "dev": "deno run --allow-run=deno tasks.ts dev",
    "check": "deno check src/cli.ts tasks.ts && deno lint && deno fmt --check",
    "test": "deno test -A",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "compile": "deno run --allow-run=deno tasks.ts compile",
    "install": "deno run --allow-run=deno tasks.ts install"
  },
  "imports": {
    "@std/async": "jsr:@std/async@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "fflate": "npm:fflate@^0.8"
  },
  "fmt": {
    "lineWidth": 100
  },
  "exclude": ["freellama"]
}
