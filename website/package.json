{
  "name": "freellama-website",
  "description": "Documentation website for freellama — run LLMs locally, powered by llama.cpp.",
  "dependencies": {
    "@comp0/react": "0.1.0-next.0",
    "isbot": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.18.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@react-router/dev": "7.18.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-plugin-better-tailwindcss": "4.7.0",
    "prettier": "3.9.5",
    "react-refresh": "0.18.0",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vite-tsconfig-paths": "5.1.4",
    "wrangler": "4.112.0"
  },
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "private": true,
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types && react-router typegen",
    "check": "tsc && react-router build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "react-router dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "preview": "vite preview",
    "typecheck": "wrangler types && react-router typegen && tsc -b"
  },
  "type": "module"
}
