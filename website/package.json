{
	"name": "freellama-website",
	"description": "Documentation website for freellama — run LLMs locally, powered by llama.cpp.",
	"dependencies": {
		"@comp0/react": "0.1.0-next.0",
		"isbot": "5.1.32",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-router": "7.9.6"
	},
	"devDependencies": {
		"@react-router/dev": "7.9.6",
		"@tailwindcss/vite": "4.1.17",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@typescript-eslint/parser": "^8.64.0",
		"eslint": "^10.7.0",
		"eslint-plugin-better-tailwindcss": "^4.6.1",
		"tailwindcss": "4.1.17",
		"typescript": "5.9.3",
		"vite": "^7.0.0",
		"vite-tsconfig-paths": "5.1.4",
		"wrangler": "4.88.0"
	},
	"packageManager": "pnpm@10.33.0",
	"private": true,
	"scripts": {
		"build": "react-router build",
		"check": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check && pnpm run build && wrangler deploy --dry-run",
		"deploy": "pnpm run build && wrangler deploy",
		"dev": "react-router dev",
		"fmt": "deno fmt",
		"fmt:check": "deno fmt --check",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"preview": "vite preview",
		"typecheck": "react-router typegen && tsc -b"
	},
	"type": "module"
}
